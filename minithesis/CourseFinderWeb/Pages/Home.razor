@page "/"
@inject NavigationManager Navigation
@using CourseFinderWeb.Models

<div style="padding: 20px; display: flex; flex-direction: column; align-items: center; min-height: 80vh;">
    
    <div style="text-align: center; margin-bottom: 20px;">
        <h1 style="font-size: 2.2rem; margin-bottom: 5px; color: var(--text-main);">CareerMatch</h1>
        <p class="section-subtitle">Swipe right if it matches you. Swipe left if not.</p>
        <p style="color: var(--primary-dark); font-weight: bold; font-size: 0.9rem;">
            Card @(_currentIndex + 1) of @(_deck.Count)
        </p>
    </div>

    @if (_currentIndex < _deck.Count)
    {
        var currentItem = _deck[_currentIndex];
        
        <div class="flashcard-container">
            <div class="flashcard @_animationClass" 
                 @onpointerdown="OnPointerDown"
                 @onpointermove="OnPointerMove"
                 @onpointerup="OnPointerUp"
                 @onpointerleave="OnPointerUp"
                 style="@_cardStyle">
                 
                 <p class="category-label">@currentItem.Category</p>
                 <h2>@currentItem.Text</h2>
                 
                 <div style="margin-top: 30px; color: var(--text-muted); font-size: 0.9rem; font-weight: 500;">
                    (Drag or tap a button below)
                 </div>
            </div>
        </div>

        <div class="card-actions">
            <button class="action-btn btn-nope" @onclick="SwipeLeft">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
            <button class="action-btn btn-yes" @onclick="SwipeRight">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
            </button>
        </div>
    }
    else
    {
        <div style="text-align: center; margin-top: 50px;">
            <div class="loading-progress">
                <svg width="60" height="60" viewBox="0 0 50 50" class="spinner" style="animation: rotate 2s linear infinite;">
                    <circle cx="25" cy="25" r="20" fill="none" stroke="var(--primary)" stroke-width="5" stroke-dasharray="1, 200" stroke-dashoffset="0" stroke-linecap="round" style="animation: dash 1.5s ease-in-out infinite;"></circle>
                </svg>
            </div>
            <p style="font-size: 1.2rem; font-weight: bold; margin-top: 20px; color: var(--text-main);">Calculating your perfect matches...</p>
        </div>
        
        <style>
            @@keyframes rotate { 100% { transform: rotate(360deg); } }
            @@keyframes dash {
                0% { stroke-dasharray: 1, 200; stroke-dashoffset: 0; }
                50% { stroke-dasharray: 90, 200; stroke-dashoffset: -35px; }
                100% { stroke-dasharray: 90, 200; stroke-dashoffset: -124px; }
            }
        </style>
    }

</div>

@code {
    private class DeckItem
    {
        public string Category { get; set; }
        public string Text { get; set; }
    }

    private List<string> _skills = new() { "Logic", "Problem Solving", "Creativity", "Leadership", "Communication" };
    private List<string> _knowledge = new() { "Technology", "Science", "Business", "Mathematics", "Arts" };
    private List<string> _hobbies = new() { "Gaming", "Coding", "Drawing", "Writing", "Sports" };

    private List<DeckItem> _deck = new();
    private int _currentIndex = 0;

    private List<string> _selectedSkills = new();
    private List<string> _selectedKnowledge = new();
    private List<string> _selectedHobbies = new();

    // Interaction State
    private bool _isDragging = false;
    private double _startX = 0;
    private double _currentX = 0;
    private string _animationClass = "";

    protected override void OnInitialized()
    {
        // Build the deck by mixing categories
        foreach (var s in _skills) _deck.Add(new DeckItem { Category = "Skill", Text = s });
        foreach (var k in _knowledge) _deck.Add(new DeckItem { Category = "Knowledge", Text = k });
        foreach (var h in _hobbies) _deck.Add(new DeckItem { Category = "Hobby", Text = h });

        // Shuffle the deck:
        var rng = new Random();
        _deck = _deck.OrderBy(x => rng.Next()).ToList();
    }

    private string _cardStyle
    {
        get
        {
            if (_isDragging)
            {
                var deltaX = _currentX - _startX;
                var rotation = deltaX * 0.1; // Add an angle to the drag
                return $"transform: translate({deltaX}px, 0) rotate({rotation}deg); transition: none;";
            }
            return "";
        }
    }

    private void OnPointerDown(PointerEventArgs e)
    {
        _isDragging = true;
        _startX = e.ClientX;
        _currentX = e.ClientX;
        _animationClass = ""; // Clear any active animation
    }

    private void OnPointerMove(PointerEventArgs e)
    {
        if (_isDragging)
        {
            _currentX = e.ClientX;
        }
    }

    private async Task OnPointerUp(PointerEventArgs e)
    {
        if (!_isDragging) return;
        _isDragging = false;

        var deltaX = _currentX - _startX;
        var threshold = 100; // Pixels needed to throw the card

        if (deltaX > threshold)
        {
            await SwipeRight();
        }
        else if (deltaX < -threshold)
        {
            await SwipeLeft();
        }
        else
        {
            // Snap back
            _animationClass = "";
        }
    }

    private async Task SwipeLeft()
    {
        _animationClass = "swipe-out-left";
        await Task.Delay(300); // Wait for animation
        NextCard(false);
    }

    private async Task SwipeRight()
    {
        _animationClass = "swipe-out-right";
        await Task.Delay(300); // Wait for animation
        NextCard(true);
    }

    private void NextCard(bool accepted)
    {
        var item = _deck[_currentIndex];
        
        if (accepted)
        {
            if (item.Category == "Skill") _selectedSkills.Add(item.Text);
            else if (item.Category == "Knowledge") _selectedKnowledge.Add(item.Text);
            else if (item.Category == "Hobby") _selectedHobbies.Add(item.Text);
        }

        _currentIndex++;
        _animationClass = ""; // Reset animation for next card
        StateHasChanged();

        if (_currentIndex >= _deck.Count)
        {
            FinishAssessment();
        }
    }

    private void FinishAssessment()
    {
        AssessmentDataState.Current = new UserAssessment
        {
            SelectedSkills = _selectedSkills,
            SelectedKnowledge = _selectedKnowledge,
            SelectedHobbies = _selectedHobbies
        };

        Navigation.NavigateTo("/results");
    }

    public static class AssessmentDataState
    {
        public static UserAssessment Current { get; set; }
    }
}
