<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CourseFinder.AssessmentPage"
             Title="Discovery Assessment"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="25">
            
            <Label Text="Tell us about yourself"
                   Style="{StaticResource Headline}"
                   FontSize="28"
                   HorizontalOptions="Start" />
            
            <!-- Skills Section -->
            <VerticalStackLayout Spacing="10">
                <Label Text="Your Skills" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource PrimaryLight}" />
                <Label Text="What are you good at?" FontSize="14" TextColor="{StaticResource Gray400}" />
                
                <FlexLayout x:Name="SkillsLayout" Wrap="Wrap" JustifyContent="Start" AlignContent="Start" AlignItems="Start" Direction="Row">
                    <!-- Checkboxes will be added here -->
                </FlexLayout>
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="{StaticResource SurfaceVariant}" Margin="0,10" />

            <!-- Knowledge Section -->
            <VerticalStackLayout Spacing="10">
                <Label Text="Your Knowledge" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource PrimaryLight}" />
                <Label Text="What topics do you know most about?" FontSize="14" TextColor="{StaticResource Gray400}" />
                
                <FlexLayout x:Name="KnowledgeLayout" Wrap="Wrap" JustifyContent="Start" AlignContent="Start" AlignItems="Start" Direction="Row">
                    <!-- Checkboxes will be added here -->
                </FlexLayout>
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="{StaticResource SurfaceVariant}" Margin="0,10" />

            <!-- Hobbies Section -->
            <VerticalStackLayout Spacing="10">
                <Label Text="Your Hobbies" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource PrimaryLight}" />
                <Label Text="What do you enjoy doing in your free time?" FontSize="14" TextColor="{StaticResource Gray400}" />
                
                <FlexLayout x:Name="HobbiesLayout" Wrap="Wrap" JustifyContent="Start" AlignContent="Start" AlignItems="Start" Direction="Row">
                    <!-- Checkboxes will be added here -->
                </FlexLayout>
            </VerticalStackLayout>

            <Button Text="See Recommendations"
                    Clicked="OnCalculateClicked"
                    BackgroundColor="{StaticResource Accent}"
                    TextColor="{StaticResource White}"
                    HeightRequest="56"
                    CornerRadius="28"
                    Margin="0,40,0,20" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
